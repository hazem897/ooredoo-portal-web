# backend/.env - FICHIER DE CONFIGURATION (EXEMPLE)

# ✅ DATABASE
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=1920
DB_NAME=ooredoo_portal

# ✅ JWT
JWT_SECRET=ooredoo_secret_key_2025

# ✅ EMAIL
EMAIL_USER=votre_email@gmail.com
EMAIL_PASS=votre_mot_de_passe_app
EMAIL_FROM="Ooredoo Portal" <noreply@ooredoo.tn>

# ✅ SERVER
PORT=5000
DEV_MODE=true

# ✅ ADMIN
ADMIN_EMAIL=admin@ooredoo.tn
BASE_URL=http://localhost:5000

# NOTES:
# - DEV_MODE=true: OTP affiché sur le frontend
# - DEV_MODE=false: OTP envoyé par email (prod)
# - EMAIL_PASS: Password app Gmail (pas le mot de passe normal)
#   Générer ici: https://myaccount.google.com/apppasswords
