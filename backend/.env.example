# ────────────────────────────────────────
# 🔐 DATABASE CONFIGURATION (PostgreSQL)
# ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_NAME=ooredoo_portal

# ────────────────────────────────────────
# 🔑 SECURITY KEYS
# ────────────────────────────────────────
JWT_SECRET=change_me_to_a_very_long_random_secret_key_2025

# ────────────────────────────────────────
# 📧 EMAIL CONFIGURATION (Gmail or SMTP)
# ────────────────────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_not_regular_password
EMAIL_FROM="Ooredoo Portal" <noreply@ooredoo.tn>

# Optional: Alternative SMTP (Brevo, SendGrid, etc.)
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587

# ────────────────────────────────────────
# 🚀 SERVER CONFIGURATION
# ────────────────────────────────────────
PORT=5000
DEV_MODE=false

# ────────────────────────────────────────
# 👨‍💼 ADMIN NOTIFICATION
# ────────────────────────────────────────
ADMIN_EMAIL=admin@ooredoo.tn
BASE_URL=http://localhost:3000

# ────────────────────────────────────────
# ⚠️  IMPORTANT SECURITY REMINDERS
# ────────────────────────────────────────
# 1. Never commit .env file to Git! Only commit .env.example
# 2. Use strong passwords (min 16 characters)
# 3. JWT_SECRET must be at least 32 characters
# 4. For Gmail: Use App Password, NOT your regular password
# 5. Keep this file in .gitignore
